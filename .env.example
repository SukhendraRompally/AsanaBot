# Asana Agent — Moveworks Reference Implementation
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── Asana ──────────────────────────────────────────────────────────────────
# Generate at: Asana → My Profile Settings → Apps → Manage Developer Apps → Create new token
ASANA_PAT=your_asana_personal_access_token_here

# ── Azure OpenAI ───────────────────────────────────────────────────────────
# Found in: Azure Portal → Cognitive Services → Keys and Endpoint
AZURE_OPENAI_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1
AZURE_OPENAI_VERSION=2024-02-01
